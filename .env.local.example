NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

RESEND_API_KEY=
# Required in production (Vercel → Settings → Environment Variables). .env.local is local only.
RESEND_FROM_EMAIL=RidgeTheory <hello@your-verified-domain.com>
# Optional. If set, overrides RESEND_FROM_EMAIL. Leave unset until you have a verified outreach address.
# OUTREACH_FROM_EMAIL=RidgeTheory <outreach@your-verified-domain.com>

REOON_API_KEY=
REOON_VERIFY_MODE=power

OUTREACH_PHONE=(424) 273-5737
